-- ========================
--  PROTEÇÃO ANTI-TAMPER
-- ========================
local function AntiTamper()
    local mt = getmetatable(game)
    if mt and mt.__newindex then
        local oldnewindex = mt.__newindex
        mt.__newindex = function(t, k, v)
            if k == "Script" or k == "LocalScript" then
                error("🚫 Modificação de scripts bloqueada.", 2)
            end
            return oldnewindex(t, k, v)
        end
    end
end

local function Obfuscate()
    local debug = getfenv()
    debug.getinfo = nil
    debug.traceback = nil
    setreadonly(print, true)
end

AntiTamper()
Obfuscate()

